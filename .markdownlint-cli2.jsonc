{
  // Markdownlint config for the Product Office repo.
  //
  // Pragmatic stance: the repo uses tight heading->list/table formatting
  // throughout (40+ files), as a consistent stylistic convention.
  // GitHub renders these fine without blank lines. Fighting the convention
  // would mean rewriting every doc; that is not what a housekeeping PR is for.
  //
  // We therefore disable the rules that fire on this stylistic choice but
  // do NOT cause rendering bugs:
  //   MD013 (line-length 80)              - too aggressive for prose
  //   MD022 (blanks-around-headings)      - repo convention; renders fine
  //   MD024 (no-duplicate-heading)        - common across nested CLAUDE.md files
  //   MD025 (single-h1)                   - command/agent docs intentionally use multiple H1
  //   MD031 (blanks-around-fences)        - repo convention; renders fine
  //   MD032 (blanks-around-lists)         - repo convention; renders fine
  //   MD033 (no-inline-html)              - slash-command placeholders trigger it
  //   MD034 (no-bare-urls)                - README badge URLs are easier bare
  //   MD036 (no-emphasis-as-heading)      - sometimes legitimate in skill files
  //   MD041 (first-line-heading)          - frontmatter throws this off
  //
  //   MD040 (fenced-code-language)         - many agent docs use bare ``` blocks
  //                                          intentionally for non-code samples
  //                                          (configs, env vars, prose-shaped text)
  //
  // Rules that still catch real bugs (and stay enabled by default):
  //   MD042 (no-empty-links)
  //   MD046 (code-block-style)
  //   MD050/051 (table/link reference issues)
  // Final cosmetic-style disables (round 5) — settled repo conventions:
  //   MD001 (heading-increment)  - some docs skip H2 and go straight to H3
  //   MD004 (ul-style)           - repo uses dashes everywhere (markdownlint
  //                                 default is asterisk)
  //   MD009 (trailing-spaces)    - templates with placeholder lines have
  //                                 incidental trailing whitespace
  //   MD049 (emphasis-style)     - repo uses underscores for emphasis
  //                                 (markdownlint default is asterisk)
  // Round 6 disables:
  //   MD003 (heading-style)        repo mixes ATX and Setext styles
  //   MD012 (no-multiple-blanks)   governance/framework.md uses double blanks
  //                                  as paragraph separators in long sections
  //   MD055 (table-style)          repo uses different table border styles
  //
  // MD056 (table-column-count) was temporarily disabled to unblock the
  // chore: agents-mirror-and-housekeeping PR. Re-enabled after the
  // governance/framework.md spreadsheet-layout tables were corrected to
  // include a leading row-label column in the header (was a real GitHub
  // rendering bug: extra body cells were silently dropped).
  "config": {
    "MD001": false,
    "MD003": false,
    "MD004": false,
    "MD009": false,
    "MD012": false,
    "MD013": false,
    "MD022": false,
    "MD024": false,
    "MD025": false,
    "MD031": false,
    "MD032": false,
    "MD033": false,
    "MD034": false,
    "MD036": false,
    "MD040": false,
    "MD041": false,
    "MD049": false,
    "MD055": false
  },
  "globs": [
    "**/*.md"
  ],
  "ignores": [
    "node_modules",
    ".git",
    "governance/.tmp",
    // Archived design specs from prior sessions — preserved verbatim,
    // not actively maintained.
    "docs/superpowers/specs/**"
  ]
}
